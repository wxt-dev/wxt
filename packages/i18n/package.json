{
  "name": "@wxt-dev/i18n",
  "description": "Type-safe wrapper around browser.i18n.getMessage with additional features",
  "version": "0.2.5",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wxt-dev/wxt.git",
    "directory": "packages/i18n"
  },
  "homepage": "http://wxt.dev/guide/i18n/installation.html",
  "keywords": [
    "wxt",
    "module",
    "i18n"
  ],
  "author": {
    "name": "Aaron Klinker",
    "email": "aaronklinker1+wxt@gmail.com"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/wxt-dev",
  "scripts": {
    "build": "vp pack",
    "check": "check",
    "test": "vp test",
    "test:coverage": "vp test --coverage",
    "prepack": "vp pack"
  },
  "dependencies": {
    "@wxt-dev/browser": "workspace:^",
    "chokidar": "^5.0.0",
    "confbox": "^0.2.4",
    "tinyglobby": "^0.2.15"
  },
  "peerDependencies": {
    "wxt": ">=0.19.7"
  },
  "peerDependenciesMeta": {
    "wxt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "publint": "^0.3.18",
    "typescript": "^5.9.3",
    "vitest": "catalog:",
    "vitest-plugin-random-seed": "^1.1.2",
    "wxt": "workspace:*",
    "vite-plus": "catalog:"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./build": {
      "import": {
        "types": "./dist/build.d.mts",
        "default": "./dist/build.mjs"
      },
      "require": {
        "types": "./dist/build.d.cts",
        "default": "./dist/build.cjs"
      }
    },
    "./module": {
      "import": {
        "types": "./dist/module.d.mts",
        "default": "./dist/module.mjs"
      },
      "require": {
        "types": "./dist/module.d.cts",
        "default": "./dist/module.cjs"
      }
    }
  },
  "files": [
    "dist"
  ]
}
