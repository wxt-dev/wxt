{
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.5"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vp run -r test run",
    "test:coverage": "vp run -r test:coverage",
    "docs:gen": "typedoc --options docs/typedoc.json",
    "docs:dev": "bun run --silent docs:gen && bun run --bun vitepress dev docs",
    "docs:build": "bun run --silent docs:gen && bun run --bun vitepress build docs",
    "docs:preview": "bun run --silent docs:gen && bun run --bun vitepress preview docs",
    "postinstall": "[ \"$NETLIFY\" = \"true\" ] || vp run -r postinstall"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.3",
    "@commitlint/types": "^20.4.3",
    "@types/bun": "^1.3.5",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.0.18",
    "changelogen": "^0.6.2",
    "consola": "^3.4.2",
    "cspell": "^9.7.0",
    "feed": "^5.2.0",
    "markdown-it-footnote": "^4.0.0",
    "markdownlint-cli": "^0.48.0",
    "nano-spawn": "^2.0.0",
    "p-map": "^7.0.4",
    "pkg-pr-new": "^0.0.66",
    "semver": "^7.7.4",
    "tinyglobby": "^0.2.15",
    "tsx": "4.21.0",
    "typedoc": "^0.25.4",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "4.0.0-next.23",
    "typedoc-vitepress-theme": "1.0.0-next.3",
    "typescript": "^5.9.3",
    "vite-plus": "catalog:",
    "vitepress": "^1.6.4",
    "vitepress-knowledge": "^0.4.1",
    "vitepress-plugin-group-icons": "^1.7.3",
    "vitepress-plugin-llms": "^1.12.0",
    "vitest": "catalog:",
    "vitest-mock-extended": "^3.1.0",
    "vue": "^3.5.29",
    "wxt": "workspace:*"
  },
  "patchedDependencies": {
    "markdown-it-footnote@4.0.0": "patches/markdown-it-footnote.patch",
    "pkg-pr-new@0.0.66": "patches/pkg-pr-new@0.0.66.patch"
  },
  "packageManager": "bun@1.3.12",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.20",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.20",
    "vite-plus": "^0.1.20"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
